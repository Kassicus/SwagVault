# Copy to .env.local and fill in. Never commit real secrets.
# Most of these are auto-injected on Vercel via the Supabase Marketplace integration.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Server-side keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for the two SwagVault Pro plans
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Public publishable key (only needed if you ever embed Elements; Checkout doesn't require it client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend ---
RESEND_API_KEY=
# From-address for transactional mail (must be a verified Resend domain/sender)
RESEND_FROM_EMAIL=

# --- Vercel Blob (for currency icons, product images) ---
# Auto-injected by Vercel when you create a Blob store in the dashboard.
# Pull with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# --- Feature flags ---
# Set to "true" once Stripe is fully wired up. While false, signup skips the
# plan-select step, orgs are created as `active`, and /admin/billing renders a
# placeholder instead of opening Stripe's Customer Portal.
BILLING_ENABLED=false

# --- App ---
# Public origin used to build absolute URLs (invite links, Stripe success/cancel URLs, email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
